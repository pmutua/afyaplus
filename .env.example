# =============================================================================
# This file configures the AfyaPlus RAG Agent System (app/) only.
#
# Triage Engine (triage/engine.py) is a separate capability with its own
# environment - see triage/env.example / triage/.env. Do not add Triage's
# OpenRouter/OpenAI/unprefixed OLLAMA_* vars here; they belong there instead.
# =============================================================================

# =============================================================================
# RAG Agent System (app/) - chat model provider (app/config.py).
#
# MODEL_PROVIDER selects the transport: "ollama_local" (default) or
# "ollama_cloud". Only these two are supported - switching between them
# never requires application code changes, only these env vars. An invalid
# provider, a missing cloud model/API key, or an invalid URL fails fast at
# startup. At request time, if the configured provider fails, the agent
# retries once against the other provider - only if it's fully configured,
# and always with a logged WARNING naming both providers (see
# app/config.py's build_fallback_middleware()) - never silent.
# =============================================================================
MODEL_PROVIDER=ollama_local

# --- ollama_local ---
# The local OpenAI-compatible endpoint ignores the API key value, so
# OLLAMA_LOCAL_API_KEY may stay as the literal placeholder "ollama".
# Requires the developer to already be signed in via `ollama signin` if
# this local install proxies to Ollama Cloud.
OLLAMA_LOCAL_BASE_URL=http://localhost:11434/v1
OLLAMA_LOCAL_MODEL=llama3.2
OLLAMA_LOCAL_API_KEY=ollama
LOCAL_TIMEOUT_SECONDS=20.0

# --- ollama_cloud ---
# Talks directly to https://ollama.com (Authorization: Bearer
# OLLAMA_CLOUD_API_KEY) rather than through the local Ollama install.
# OLLAMA_CLOUD_MODEL and OLLAMA_CLOUD_API_KEY are required when
# MODEL_PROVIDER=ollama_cloud - never use the placeholder value "ollama"
# here, it will not authenticate against Ollama Cloud.
#
# To switch this deployment to production Ollama Cloud: set
# MODEL_PROVIDER=ollama_cloud above, then uncomment and fill in both lines
# below with a real key from https://ollama.com/settings/keys. Never commit
# the real value - this file only ships the placeholder shape.
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
# OLLAMA_CLOUD_MODEL=gpt-oss:120b
# OLLAMA_CLOUD_API_KEY=<your-real-ollama-cloud-api-key>
CLOUD_TIMEOUT_SECONDS=30.0

# Maximum conversation-history tokens sent to the chat model per call.
# Leaves the rest of its 4096-token context for prompts, tools, and output.
AGENT_HISTORY_TOKEN_BUDGET=2048

# =============================================================================
# Managed RAG embeddings and vector storage (Qdrant Cloud Inference).
#
# Put real values only in the gitignored .env and deployment secret manager.
# The collection below is application-only; do not reuse tooling/MCP
# collections such as afyaplus-claude-notes.
# =============================================================================
QDRANT_URL=<your-qdrant-cluster-https-endpoint>
QDRANT_API_KEY=<your-real-qdrant-api-key>
QDRANT_COLLECTION_NAME=afyaplus_knowledge_base
QDRANT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QDRANT_EMBEDDING_DIMENSIONS=384
QDRANT_TIMEOUT_SECONDS=30.0
