# Cloud pathway: Option A, OpenRouter
OPENROUTER_API_KEY=sk-your-openrouter-key-here
MODEL_BASE_URL=https://openrouter.ai/api/v1
CLOUD_MODEL=openai/gpt-4o-mini

# Cloud pathway: Option B, direct OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here
# MODEL_BASE_URL=https://api.openai.com/v1
# CLOUD_MODEL=gpt-4o-mini

# Local Ollama pathway
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=ollama
LOCAL_TIMEOUT_SECONDS=20.0

# RAG embedding model (rag/retrieval.py build_embedding_model()), via
# Ollama - reuses OLLAMA_BASE_URL above. Same model for local development
# (Ollama on localhost) and production (self-hosted Ollama elsewhere) -
# only OLLAMA_BASE_URL differs between them. CI always overrides this to
# DeterministicHashEmbedding instead; CI is not set here on purpose - it's
# an ambient var most CI providers (GitHub Actions, GitLab CI, etc.) set
# automatically, not something to configure in a local .env.
# Valid values: embeddinggemma | all-minilm (pull whichever with
# `ollama pull <model>` first)
OLLAMA_EMBEDDING_MODEL=embeddinggemma
