# Cloud pathway: Option A, OpenRouter
OPENROUTER_API_KEY=sk-your-openrouter-key-here
MODEL_BASE_URL=https://openrouter.ai/api/v1
CLOUD_MODEL=openai/gpt-4o-mini

# Cloud pathway: Option B, direct OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here
# MODEL_BASE_URL=https://api.openai.com/v1
# CLOUD_MODEL=gpt-4o-mini

# Local Ollama pathway
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=ollama
LOCAL_TIMEOUT_SECONDS=20.0

# RAG embedding provider (rag/retrieval.py build_embedding_model()).
# Leave EMBEDDING_PROVIDER unset to auto-detect: cloud key present ->
# Ollama reachable -> Hugging Face installed -> DeterministicHashEmbedding.
# Set it explicitly to force one tier (openrouter, openai, ollama,
# huggingface, or deterministic); CI always overrides this to
# deterministic. CI is not set here on purpose - it's an ambient var most
# CI providers (GitHub Actions, GitLab CI, etc.) set automatically, not
# something to configure in a local .env.
EMBEDDING_PROVIDER=openrouter
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
# EMBEDDING_MODEL=text-embedding-3-small
# OLLAMA_EMBEDDING_MODEL=embeddinggemma
