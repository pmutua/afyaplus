# Triage Engine (triage/engine.py) - own environment, independent of the
# RAG Agent System's root .env.example (app/config.py).
#
# Copy this file to triage/.env - not the repo-root .env - and fill in
# real credentials there. triage/engine.py loads triage/.env explicitly by
# path, so placing values in the repo-root .env instead will not work.

# Cloud pathway: Option A, OpenRouter
OPENROUTER_API_KEY=sk-your-openrouter-key-here
MODEL_BASE_URL=https://openrouter.ai/api/v1
CLOUD_MODEL=openai/gpt-4o-mini

# Cloud pathway: Option B, direct OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here
# MODEL_BASE_URL=https://api.openai.com/v1
# CLOUD_MODEL=gpt-4o-mini

# Local Ollama pathway (fallback when the cloud pathway is unavailable)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=ollama
LOCAL_TIMEOUT_SECONDS=20.0
